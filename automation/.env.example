# Anthropic API キー
# https://console.anthropic.com から取得
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxx

# Gmail設定
# 注意: 通常パスワードではなく「アプリパスワード」を使用してください
# 設定方法: Google アカウント → セキュリティ → 2段階認証 → アプリパスワード
GMAIL_ADDRESS=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# 鑑定士のメールアドレス（送信元として表示）
FORTUNE_EMAIL=uranai@kamiya-shun.jp
